# ── モデルファイル（LightGBM バイナリ・数百MB） ───────────────────────────
# 2026-07: 先頭スラッシュが無かったため pace_bias_ai/models/ や src/models/ 等
# ソースコードを含むディレクトリまで無視されていた（layer2_model.py 等が
# 一度も git 追跡されていなかった）。ルート直下の models/ のみ対象にする。
/models/
*.lgb
*.pkl
*.joblib
*.onnx

# ── 学習・推論データ（Parquet・数GB） ─────────────────────────────────────
data/parquet/
data/outputs/
data/output/
data/input/
data/jobs/
data/predictions/
*.parquet

# ── 中間出力（CSV・JSON 一時ファイル） ────────────────────────────────────
outputs/
reports/
logs/
scripts/backtest_*results*.csv
scripts/backtest_v*.csv
_tmp_*.csv

# ── 環境変数・秘密情報 ────────────────────────────────────────────────────
.env
.env.local
.env.production

# ── Python キャッシュ ─────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage

# ── Node / フロントエンド ─────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/

# ── admin_frontend ────────────────────────────────────────────────────────────
admin_frontend/node_modules/
admin_frontend/dist/
admin_frontend/.vite/
admin_frontend/.env.local
admin_frontend/.env.production

# ── OS / エディタ ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/settings.json
*.swp

# ── Claude Code ローカル設定（共有しない） ────────────────────────────────
.claude/

# ── アーカイブ・旧コード ──────────────────────────────────────────────────
# 2026-07: archive/ は「歴史的価値のみ残す」場所として使われており、
# git管理外だとリモート/他メンバーから参照できず archive の役割を果たさない
# ことが判明したため、追跡対象に変更した。
_archive/

# ── デバッグ・一時スクリプト ──────────────────────────────────────────────
_check_*.py
_explain_*.py
_tmp_*
fable_audit_prompt.md

# ── フロントエンド デバッグスクリプト ────────────────────────────────────
frontend/_test_*.mjs
frontend/_tmp_shot*.mjs
frontend/screenshot.mjs

# ── 除外しない（git で明示管理するもの） ──────────────────────────────────
# course_physical_master.csv は人間精査済みマスタなので必ず管理対象にする
!data/masters/
!data/masters/*.csv
!data/masters/*.json
