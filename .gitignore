# ── モデルファイル（LightGBM バイナリ・数百MB） ───────────────────────────
models/
*.lgb
*.pkl
*.joblib
*.onnx

# ── 学習・推論データ（Parquet・数GB） ─────────────────────────────────────
data/parquet/
data/outputs/
data/output/
data/input/
data/jobs/
data/predictions/
*.parquet

# ── 中間出力（CSV・JSON 一時ファイル） ────────────────────────────────────
outputs/
reports/
logs/
scripts/backtest_*results*.csv
scripts/backtest_v*.csv
_tmp_*.csv

# ── 環境変数・秘密情報 ────────────────────────────────────────────────────
.env
.env.local
.env.production

# ── Python キャッシュ ─────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage

# ── Node / フロントエンド ─────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/

# ── admin_frontend ────────────────────────────────────────────────────────────
admin_frontend/node_modules/
admin_frontend/dist/
admin_frontend/.vite/
