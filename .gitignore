admin_frontend/.env.production

# ── owl_video ─────────────────────────────────────────────────────────────────
owl_video/node_modules/
owl_video/out/
owl_video/public/dynamic_data/

# ── OS / エディタ ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/settings.json
*.swp

# ── Claude Code ローカル設定（共有しない） ────────────────────────────────
.claude/

# ── アーカイブ・旧コード ──────────────────────────────────────────────────
archive/
_archive/

# ── デバッグ・一時スクリプト ──────────────────────────────────────────────
_check_*.py
_explain_*.py
_tmp_*
fable_audit_prompt.md

# ── フロントエンド デバッグスクリプト ────────────────────────────────────
