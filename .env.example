# ──────────────────────────────────────────────────────────────────────────
# fukurou_v2_app 環境変数テンプレート
# .env.example をコピーして .env を作成し、各自の値を設定してください。
# .env は .gitignore で除外されているため、リポジトリにはコミットされません。
# ──────────────────────────────────────────────────────────────────────────

# ── DB: JV-Data ETL（races / race_entries テーブル）────────────────────────
DB_V2_HOST=localhost
DB_V2_PORT=5432
DB_V2_NAME=fukurou_keiba_v2
DB_V2_USER=postgres
DB_V2_PASSWORD=your_password_here

# ── DB: Feature Store（fukurou_jvdl）───────────────────────────────────────
DB_JVDL_HOST=localhost
DB_JVDL_PORT=5432
DB_JVDL_NAME=fukurou_jvdl
DB_JVDL_USER=postgres
DB_JVDL_PASSWORD=your_password_here

# ── モデルパス（リポジトリルートからの相対パス）────────────────────────────
MODEL_DIR_V2=models/v2/ensemble
SUBMODEL_DIR_V2=models/v2/submodels
MASTER_DIR=data/masters

# ── API ポート ──────────────────────────────────────────────────────────────
PORT_V1=8001
PORT_V2=8002

# ── 機能フラグ ──────────────────────────────────────────────────────────────
# DEV_MODE=true にすると、フロントエンドに動画生成ビューが表示される（開発者専用）
DEV_MODE=false
