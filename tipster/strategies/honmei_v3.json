{
  "name": "本命抽出 v3 (馬場適性必須)",
  "tipster": "fukurou",
  "type": "honmei",
  "version": "3.0",
  "_comment": "BET-5 実験用バリアント。v1 に対して track_bias_fit を required:true に変更。馬場適性不明な馬を本命候補から除外するより厳格な戦略。",
  "conditions": [
    {
      "id": "race_level",
      "enabled": true,
      "required": true,
      "params": {
        "min_next_race_horses": 3,
        "thresholds": {
          "G1":      {"place_rate": 0.20, "winner_max_rank": 7},
          "G2":      {"place_rate": 0.25, "winner_max_rank": 5},
          "G3":      {"place_rate": 0.30, "winner_max_rank": 5},
          "default": {"place_rate": 0.33, "winner_max_rank": 3}
        }
      }
    },
    {
      "id": "time_gap",
      "enabled": true,
      "required": true,
      "params": {
        "sprint_max_sec": 1.0,
        "sprint_fallback_sec": 1.5,
        "mile_max_sec": 1.5,
        "mile_fallback_sec": 2.0,
        "sprint_threshold_m": 1400
      }
    },
    {
      "id": "track_bias_fit",
      "enabled": true,
      "required": true,
      "_comment": "v1/v2 と異なり required:true。馬場適性の証明がない馬を除外する。",
      "params": {
        "exclude_on_mismatch": true
      }
    },
    {
      "id": "weight_change",
      "enabled": true,
      "required": false,
      "params": {
        "increase_penalty": -1,
        "decrease_bonus": 1,
        "apprentice_bonus_disabled": true
      }
    },
    {
      "id": "jockey_change",
      "enabled": true,
      "required": false,
      "params": {
        "top_jockey_threshold": 30,
        "stable_affinity_min_rides": 10,
        "stable_affinity_min_winrate": 0.15
      }
    }
  ],
  "ranking": {
    "primary": "condition_clear_count",
    "secondary": "ai_score",
    "max_selections": 3,
    "min_total_score": 0.0,
    "max_candidates_for_honmei": 8
  }
}
