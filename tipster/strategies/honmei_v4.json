{
  "name": "本命抽出 v4 (着差・馬場適性ダブル厳格化)",
  "tipster": "fukurou",
  "type": "honmei",
  "version": "4.0",
  "_comment": "BET-5 追加探索バリアント。v1に対して time_gap の許容着差をさらに縮め、track_bias_fit の bias_threshold を緩めて(0.2→0.35)バイアス判定の感度を下げる（不適合判定を絞り込み、誤判定での除外を減らす狙い）。v3(track_bias_fit required:true)とは異なる方向の閾値変更。",
  "conditions": [
    {
      "id": "race_level",
      "enabled": true,
      "required": true,
      "params": {
        "min_next_race_horses": 3,
        "thresholds": {
          "G1":      {"place_rate": 0.20, "winner_max_rank": 7},
          "G2":      {"place_rate": 0.25, "winner_max_rank": 5},
          "G3":      {"place_rate": 0.30, "winner_max_rank": 5},
          "default": {"place_rate": 0.33, "winner_max_rank": 3}
        }
      }
    },
    {
      "id": "time_gap",
      "enabled": true,
      "required": true,
      "_comment": "v1: sprint 1.0/1.5, mile 1.5/2.0 → さらに厳格化。",
      "params": {
        "sprint_max_sec": 0.7,
        "sprint_fallback_sec": 1.0,
        "mile_max_sec": 1.0,
        "mile_fallback_sec": 1.5,
        "sprint_threshold_m": 1400
      }
    },
    {
      "id": "track_bias_fit",
      "enabled": true,
      "required": false,
      "_comment": "v1: bias_threshold未指定(デフォルト0.2) → 0.35に緩和。バイアス不適合と判定する閾値を上げ、誤判定での減点・除外を減らす。",
      "params": {
        "exclude_on_mismatch": true,
        "bias_threshold": 0.35
      }
    },
    {
      "id": "weight_change",
      "enabled": true,
      "required": false,
      "params": {
        "increase_penalty": -1,
        "decrease_bonus": 1,
        "apprentice_bonus_disabled": true
      }
    },
    {
      "id": "jockey_change",
      "enabled": true,
      "required": false,
      "params": {
        "top_jockey_threshold": 30,
        "stable_affinity_min_rides": 10,
        "stable_affinity_min_winrate": 0.15
      }
    }
  ],
  "ranking": {
    "primary": "condition_clear_count",
    "secondary": "ai_score",
    "max_selections": 3
  }
}
