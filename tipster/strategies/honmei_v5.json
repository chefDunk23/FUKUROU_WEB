{
  "name": "本命抽出 v5 (TR-1調教ランキング上位を加点)",
  "tipster": "fukurou",
  "type": "honmei",
  "version": "5.0",
  "_comment": "BET-5 追加探索バリアント。v1の5条件に加え、TR-1（調教AIフィルタリング、tipster/training_ranker.py）の優先度ランキング上位3位以内を加点条件として追加（tipster/conditions_tr1.pyのtraining_rank_top、required:falseのためTR-1データ不足でも本命候補から除外されない）。v1（TR-1組み込みなし）との回収率比較のためのバリアント。",
  "conditions": [
    {
      "id": "race_level",
      "enabled": true,
      "required": true,
      "params": {
        "min_next_race_horses": 3,
        "thresholds": {
          "G1":      {"place_rate": 0.20, "winner_max_rank": 7},
          "G2":      {"place_rate": 0.25, "winner_max_rank": 5},
          "G3":      {"place_rate": 0.30, "winner_max_rank": 5},
          "default": {"place_rate": 0.33, "winner_max_rank": 3}
        }
      }
    },
    {
      "id": "time_gap",
      "enabled": true,
      "required": true,
      "params": {
        "sprint_max_sec": 1.0,
        "sprint_fallback_sec": 1.5,
        "mile_max_sec": 1.5,
        "mile_fallback_sec": 2.0,
        "sprint_threshold_m": 1400
      }
    },
    {
      "id": "track_bias_fit",
      "enabled": true,
      "required": false,
      "params": {
        "exclude_on_mismatch": true
      }
    },
    {
      "id": "weight_change",
      "enabled": true,
      "required": false,
      "params": {
        "increase_penalty": -1,
        "decrease_bonus": 1,
        "apprentice_bonus_disabled": true
      }
    },
    {
      "id": "jockey_change",
      "enabled": true,
      "required": false,
      "params": {
        "top_jockey_threshold": 30,
        "stable_affinity_min_rides": 10,
        "stable_affinity_min_winrate": 0.15
      }
    },
    {
      "id": "training_rank_top",
      "enabled": true,
      "required": false,
      "_comment": "tipster/conditions_tr1.py で新規追加。TR-1優先度ランキング上位3位以内を加点(required:false)。",
      "params": {
        "top_n": 3,
        "bonus_score": 1.5,
        "penalty_score": 0.0
      }
    }
  ],
  "ranking": {
    "primary": "condition_clear_count",
    "secondary": "ai_score",
    "max_selections": 3
  }
